# Shared secret between security-ai service and its callers (dashboard server, gateway).
# Required — security-ai always returns 401 without it.
AGRUS_INTERNAL_TOKEN=changeme-internal-token

# Shared secret between sensors (Linux/Windows) and the Go gateway.
# Required — gateway exits immediately without it.
AGRUS_SENSOR_TOKEN=changeme-sensor-token

# Where sensors send telemetry. Defaults to local gateway.
AGRUS_GATEWAY_URL=http://127.0.0.1:8080/api/v1/telemetry

# Rust logging verbosity for sensors.
RUST_LOG=info

# --- AI Remediation & GitHub PR Automation ---
# Set to "true" to allow the AI to push branches to origin automatically
AGRUS_REMEDIATION_AUTO_PUSH=false
# Required to open the Pull Request via the GitHub API (must have 'repo' scope)
GITHUB_TOKEN=ghp_your_personal_access_token_here
